{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "SMBX Tea",
	"scopeName": "source.smt",
	"patterns": [
		{ "include": "#comment" },
		{ "include": "#declare" },
		{ "include": "#keywords" },
		{ "include": "#expression" }
	],
	"repository": {
		"keywords": {
			"patterns": [
				{ "include": "#buildin_type" },
				{ "include": "#support" },
				{
					"name": "keyword.control.smbxtea",
					"match": "(?i)\\b(as|call|case|continue|dim|do|else|elseif|end|exit|export|for|gosub|goto|if|loop|next|return|script|select|step|then|to|until|while|with|redim)\\b"
				}
			]
		},
		"support": {
			"patterns": [
				{
					"comment": "内建函数/全局变量访问器: Array(...), Val(...), GVal(...), Str(...), GStr(...), V(...), GV(...)",
					"name": "support.function.smbxtea",
					"match": "(?i)\\b(?:Array|GVal|Val|Str|GStr|GV|V)(?=\\s*\\()"
				}
			]
		},
		"strings": {
			"name": "string.quoted.double.smbxtea",
			"begin": "\"",
			"end": "\"|$",
			"patterns": [
				{
					"name": "constant.character.escape.smbxtea",
					"match": "\\\\."
				}
			]
		},
		"numeric": {
			"patterns": [
				{
					"name": "constant.numeric.smbxtea",
					"match": "\\b[0-9]+(?:\\.[0-9]+)?\\b"
				}
			]
		},
		"comment": {
			"patterns": [
				{
					"name": "comment.line.apostrophe.smbxtea",
					"match": "'.*$"
				}
			]
		},
		"buildin_type": {
			"patterns": [
				{
					"name": "storage.type.smbxtea",
					"match": "(?i)\\b(integer|double|long|byte|string|boolean|single|void)\\b"
				}
			]
		},
		"type": {
			"patterns": [
				{ "include": "#buildin_type" },
				{
					"name": "entity.name.type.smbxtea",
					"match": "\\b[_a-zA-Z][_a-zA-Z0-9]*\\b"
				}
			]
		},
		"identifier": {
			"patterns": [
				{
					"name": "variable.other.smbxtea",
					"match": "\\b[_a-zA-Z][_a-zA-Z0-9]*\\b"
				}
			]
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.word.smbxtea",
					"match": "(?i)\\b(mod|and|or|not|xor|eqv|imp|like)\\b"
				},
				{
					"name": "keyword.operator.smbxtea",
					"match": "(<<|>>|<>|<=|>=|==|=|<|>|\\+|-|\\*|/|\\\\|\\^|&|\\?|!|~)"
				},
				{
					"name": "punctuation.accessor.smbxtea",
					"match": "\\."
				}
			]
		},
		"expression_constant": {
			"patterns": [
				{ "include": "#numeric" },
				{ "include": "#strings" },
				{ "include": "#operators" }
			]
		},
		"expression": {
			"patterns": [
				{ "include": "#numeric" },
				{ "include": "#strings" },
				{ "include": "#call_function" },
				{ "include": "#field" },
				{ "include": "#operators" },
				{ "include": "#identifier" }
			]
		},
		"field": {
			"patterns": [
				{
					"comment": "对象成员: .x .id 等",
					"name": "meta.field.access.smbxtea",
					"match": "(\\.)([_a-zA-Z][_a-zA-Z0-9]*)",
					"captures": {
						"1": { "name": "punctuation.accessor.smbxtea" },
						"2": { "name": "variable.other.property.smbxtea" }
					}
				}
			]
		},
		"declare": {
			"patterns": [
				{ "include": "#declare_function" },
				{ "include": "#declare_variable" }
			]
		},
		"declare_variable": {
			"name": "meta.var.declare.smbxtea",
			"match": "(?i)(\\bdim\\s+)([_a-zA-Z][_a-zA-Z0-9]*(?:\\s*,\\s*[_a-zA-Z][_a-zA-Z0-9]*)*)(\\s+as\\s+)([_a-zA-Z][_a-zA-Z0-9]*)(.*)$",
			"captures": {
				"1": { "name": "keyword.control.declare.smbxtea" },
				"2": { "patterns": [{ "include": "#identifier" }] },
				"3": { "name": "keyword.control.declare.as.smbxtea" },
				"4": { "patterns": [{ "include": "#type" }] },
				"5": {
					"patterns": [
						{ "include": "#comment" },
						{ "include": "#expression" }
					]
				}
			}
		},
		"declare_function": {
			"name": "meta.function.declare.smbxtea",
			"begin": "(?i)(?:(\\bexport\\s+)?)(\\bscript\\s+)([_a-zA-Z][_a-zA-Z0-9]*)(\\()",
			"end": "(?i)(\\bend\\s+script\\b)",
			"beginCaptures": {
				"1": { "name": "keyword.control.export.smbxtea" },
				"2": { "name": "keyword.control.script.smbxtea" },
				"3": { "name": "entity.name.function.smbxtea" },
				"4": { "name": "punctuation.section.parens.begin.smbxtea" }
			},
			"endCaptures": {
				"1": { "name": "keyword.control.script.smbxtea" }
			},
			"patterns": [
				{ "include": "#declare_params_return" },
				{ "include": "#declare_params_variable" },
				{
					"name": "punctuation.section.parens.end.smbxtea",
					"match": "\\)"
				},
				{ "include": "#block" }
			]
		},
		"declare_params_variable": {
			"name": "meta.parameter.smbxtea",
			"match": "(?i)([_a-zA-Z][_a-zA-Z0-9]*)(\\s+as\\s+)([_a-zA-Z][_a-zA-Z0-9]*)",
			"captures": {
				"1": { "name": "variable.parameter.smbxtea" },
				"2": { "name": "keyword.control.declare.as.smbxtea" },
				"3": { "patterns": [{ "include": "#type" }] }
			}
		},
		"declare_params_return": {
			"name": "meta.return.smbxtea",
			"match": "(?i)(\\breturn\\b)\\s+([_a-zA-Z][_a-zA-Z0-9]*)",
			"captures": {
				"1": { "name": "keyword.control.return.smbxtea" },
				"2": { "patterns": [{ "include": "#type" }] }
			}
		},
		"call_function": {
			"name": "meta.function.call.smbxtea",
			"begin": "([_a-zA-Z][_a-zA-Z0-9]*)\\(",
			"end": "\\)",
			"beginCaptures": {
				"1": { "name": "entity.name.function.call.smbxtea" }
			},
			"patterns": [
				{ "include": "#expression" }
			]
		},
		"block": {
			"name": "meta.block.smbxtea",
			"patterns": [
				{ "include": "#comment" },
				{ "include": "#declare_variable" },
				{ "include": "#keywords" },
				{ "include": "#expression" }
			]
		}
	}
}
